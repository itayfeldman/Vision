digraph Vision {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=8];
    ranksep=0.7;
    nodesep=0.4;
    bgcolor="white";

    // Force vertical ordering
    { rank=same; browser; swagger; legend; }
    { rank=same; cloud_run; }
    { rank=same; r_port; r_opt; r_risk; r_fact; }
    { rank=same; s_port; s_risk; s_fact; }
    { rank=same; d_port; d_opt; d_risk; d_fact; d_mkt; }
    { rank=same; db_repo; yf; rf; }
    { rank=same; sqlite; yahoo; ff_data; }

    // ── CLIENT ──
    browser [label="Browser\n(Next.js — v0.3)", fillcolor="#FFEE58", color="#F9A825"];
    swagger [label="OpenAPI /\nSwagger UI", fillcolor="#FFEE58", color="#F9A825"];

    // ── GCP / DEPLOYMENT ──
    subgraph cluster_gcp {
        label="  Google Cloud Platform  "; labeljust=l;
        style="filled,rounded"; fillcolor="#E8EAF6"; color="#3F51B5"; penwidth=2;
        fontsize=12; fontcolor="#1A237E";

        cloud_run [label="Cloud Run\nFastAPI Container", fillcolor="#7986CB", color="#3F51B5", fontcolor="white"];

        // ── API ──
        subgraph cluster_api {
            label="  API Layer — FastAPI  "; labeljust=l;
            style="filled,rounded"; fillcolor="#E8F5E9"; color="#43A047"; penwidth=2;
            fontsize=11; fontcolor="#2E7D32";
            r_port [label="POST/GET/PUT/DELETE\n/api/portfolios", fillcolor="#A5D6A7", color="#43A047"];
            r_opt  [label="POST\n/api/optimize", fillcolor="#A5D6A7", color="#43A047"];
            r_risk [label="GET/POST\n/api/risk", fillcolor="#A5D6A7", color="#43A047"];
            r_fact [label="GET\n/api/factors", fillcolor="#A5D6A7", color="#43A047"];
        }

        // ── APPLICATION ──
        subgraph cluster_app {
            label="  Application Layer — Use Cases  "; labeljust=l;
            style="filled,rounded"; fillcolor="#EDE7F6"; color="#7E57C2"; penwidth=2;
            fontsize=11; fontcolor="#4527A0";
            s_port [label="portfolio_service\nCRUD + Optimize", fillcolor="#B39DDB", color="#5E35B1", fontcolor="white"];
            s_risk [label="risk_service\nRisk Analysis", fillcolor="#B39DDB", color="#5E35B1", fontcolor="white"];
            s_fact [label="factor_service\nFactor Decomp", fillcolor="#B39DDB", color="#5E35B1", fontcolor="white"];
        }

        // ── DOMAIN ──
        subgraph cluster_domain {
            label="  Domain Layer — Pure Business Logic  "; labeljust=l;
            style="filled,rounded"; fillcolor="#E3F2FD"; color="#1E88E5"; penwidth=2;
            fontsize=11; fontcolor="#1565C0";
            d_port [label="Portfolio Context\n──────────────\nmodels · services\n«PortfolioRepo»", fillcolor="#64B5F6", color="#1E88E5", fontcolor="white"];
            d_opt  [label="Optimization Context\n──────────────\nmodels · services\n«Optimizer»", fillcolor="#64B5F6", color="#1E88E5", fontcolor="white"];
            d_risk [label="Risk Context\n──────────────\nmodels · services", fillcolor="#64B5F6", color="#1E88E5", fontcolor="white"];
            d_fact [label="Factor Context\n──────────────\nmodels · services", fillcolor="#64B5F6", color="#1E88E5", fontcolor="white"];
            d_mkt  [label="Market Data Context\n──────────────\nmodels · services\n«MarketDataRepo»", fillcolor="#64B5F6", color="#1E88E5", fontcolor="white"];
        }

        // ── INFRASTRUCTURE ──
        subgraph cluster_infra {
            label="  Infrastructure Layer — Adapters  "; labeljust=l;
            style="filled,rounded"; fillcolor="#FFF3E0"; color="#FB8C00"; penwidth=2;
            fontsize=11; fontcolor="#E65100";
            db_repo [label="SQLite repositories.py\nimplements PortfolioRepo", fillcolor="#FFB74D", color="#FB8C00", fontcolor="white"];
            yf [label="yfinance adapter.py\nimplements MarketDataRepo", fillcolor="#FFB74D", color="#FB8C00", fontcolor="white"];
            rf [label="riskfolio adapter.py\nimplements Optimizer", fillcolor="#FFB74D", color="#FB8C00", fontcolor="white"];
        }

        // GCP Services
        gcs [label="Cloud Storage\n(GCS FUSE mount)\nSQLite persistence", fillcolor="#7986CB", color="#3F51B5", fontcolor="white"];
        secret_mgr [label="Secret Manager\nAPI keys & secrets", fillcolor="#7986CB", color="#3F51B5", fontcolor="white"];
        logging [label="Cloud Logging\n& Monitoring", fillcolor="#7986CB", color="#3F51B5", fontcolor="white"];
    }

    // ── CI/CD ──
    subgraph cluster_cicd {
        label="  CI/CD — GitHub  "; labeljust=l;
        style="filled,rounded"; fillcolor="#FAFAFA"; color="#24292E"; penwidth=2;
        fontsize=12; fontcolor="#24292E";
        github [label="GitHub\nRepository", fillcolor="#24292E", color="#24292E", fontcolor="white"];
        actions [label="GitHub Actions\ntest → build → deploy", fillcolor="#2088FF", color="#1A6DD4", fontcolor="white"];
        artifact [label="Artifact Registry\nDocker images", fillcolor="#7986CB", color="#3F51B5", fontcolor="white"];
    }

    // ── EXTERNAL ──
    subgraph cluster_ext {
        label="  External Data Services  "; labeljust=l;
        style="filled,rounded"; fillcolor="#ECEFF1"; color="#78909C"; penwidth=2;
        fontsize=12; fontcolor="#37474F";
        sqlite [label="SQLite DB\n(via GCS FUSE)", fillcolor="#B0BEC5", color="#78909C", shape=cylinder];
        yahoo [label="Yahoo Finance\nAPI", fillcolor="#B0BEC5", color="#78909C", shape=cylinder];
        ff_data [label="Fama-French\nData Library", fillcolor="#B0BEC5", color="#78909C", shape=cylinder];
    }

    // Legend
    legend [label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="2">
        <TR><TD COLSPAN="2" ALIGN="LEFT"><B>Legend</B></TD></TR>
        <TR><TD BGCOLOR="#FFEE58" BORDER="1" WIDTH="14"> </TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">Client</FONT></TD></TR>
        <TR><TD BGCOLOR="#7986CB" BORDER="1" WIDTH="14"> </TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">GCP Services</FONT></TD></TR>
        <TR><TD BGCOLOR="#A5D6A7" BORDER="1" WIDTH="14"> </TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">API (FastAPI)</FONT></TD></TR>
        <TR><TD BGCOLOR="#B39DDB" BORDER="1" WIDTH="14"> </TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">Application</FONT></TD></TR>
        <TR><TD BGCOLOR="#64B5F6" BORDER="1" WIDTH="14"> </TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">Domain</FONT></TD></TR>
        <TR><TD BGCOLOR="#FFB74D" BORDER="1" WIDTH="14"> </TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">Infrastructure</FONT></TD></TR>
        <TR><TD BGCOLOR="#24292E" BORDER="1" WIDTH="14"> </TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">GitHub CI/CD</FONT></TD></TR>
        <TR><TD BGCOLOR="#B0BEC5" BORDER="1" WIDTH="14"> </TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">External Data</FONT></TD></TR>
        <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="8">── call  - - implements</FONT></TD></TR>
        </TABLE>
    >, shape=plaintext, fillcolor="white", style=""];

    // ═══ EDGES ═══

    // Client → Cloud Run
    browser -> cloud_run;
    swagger -> cloud_run;

    // Cloud Run → API
    cloud_run -> r_port;
    cloud_run -> r_opt;
    cloud_run -> r_risk;
    cloud_run -> r_fact;

    // API → Application
    r_port -> s_port;
    r_opt -> s_port;
    r_risk -> s_risk;
    r_fact -> s_fact;

    // Application → Domain
    s_port -> d_port;
    s_port -> d_opt;
    s_port -> d_mkt;
    s_risk -> d_risk;
    s_risk -> d_mkt;
    s_fact -> d_fact;
    s_fact -> d_mkt;

    // Dependency Inversion
    d_port -> db_repo [style=dashed, color="#E65100"];
    d_mkt -> yf [style=dashed, color="#E65100"];
    d_opt -> rf [style=dashed, color="#E65100"];

    // Infrastructure → External
    db_repo -> sqlite;
    yf -> yahoo;
    d_fact -> ff_data [style=dotted, color="#999999"];

    // GCS FUSE → SQLite
    gcs -> sqlite [style=dotted, color="#3F51B5", label="  mount  "];
    db_repo -> gcs [style=dotted, color="#3F51B5"];

    // Cloud Run ← Secrets / Logging
    cloud_run -> secret_mgr [style=dotted, color="#3F51B5", dir=back];
    cloud_run -> logging [style=dotted, color="#3F51B5"];

    // CI/CD flow
    github -> actions [label="  push  "];
    actions -> artifact [label="  build  "];
    artifact -> cloud_run [label="  deploy  ", style=bold, color="#2088FF"];
}
